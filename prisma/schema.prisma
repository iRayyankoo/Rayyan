generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom Fields
  role             String  @default("USER") // USER, ADMIN
  isPro            Boolean @default(false)
  credits          Int     @default(0)
  stripeCustomerId String? @unique

  // Relations
  wallet        Wallet?
  purchases     Purchase[]
  transactions  Transaction[]
  savedItems    SavedItem[]
  notifications Notification[]

  // ERP & CRM Relations
  workspaceMembers WorkspaceMember[]
  activities       Activity[]
  tasksAssigned    Task[]
  attendances      Attendance[]
  auditLogs        AuditLog[]
  opportunities            Opportunity[] @relation("Creator")
  assignedOpportunities    Opportunity[] @relation("OppAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// Custom Application Models

model Tool {
  id                   String   @id @default(cuid())
  name                 String
  description          String
  icon                 String
  category             String
  url                  String
  isPremium            Boolean  @default(false)
  isFreeForLimitedTime Boolean  @default(false) // Shows a "Free for a limited time" badge
  isActive             Boolean  @default(true) // Switch to false to hide completely
  isMaintenance        Boolean  @default(false) // Switch to true to show as "Maintenance" but keep visible
  price                Float    @default(0.0)
  rating               Float    @default(0.0)
  installs             Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0.0)
  currency  String   @default("USD")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String // DEPOSIT, PURCHASE, REFUND
  description String?
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  String // TOOL, CREDIT_PACK
  amount    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  data      String // Stored as JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, PROMO
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// ERP & CRM Models (Tenancy, HR, Sales)
// ============================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       WorkspaceMember[]
  workgroups    Workgroup[]
  pipelineStages PipelineStage[]
  clients       Client[]
  opportunities Opportunity[]
  tasks         Task[]
  attendances   Attendance[]
  invoices      Invoice[]
  auditLogs     AuditLog[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("MEMBER") // OWNER, ADMIN, MEMBER
  joinedAt    DateTime @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workgroups  Workgroup[] @relation("WorkgroupMembers")

  @@unique([workspaceId, userId])
}

model Workgroup {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  permissions Json     @default("{}") // e.g., {"can_access_crm": true, "can_manage_tasks": true}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[] @relation("WorkgroupMembers")
}

model Client {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  company     String?
  status      String   @default("LEAD") // LEAD, ACTIVE, INACTIVE
  
  // Real Estate Fields
  interestType      String? // Investor, Buyer
  location          String? // City - District
  propertyType      String? // Land, Villa, Floor, Apartment
  financialCapacity String? // Range or Payment method
  source            String? // Snapchat, TikTok, etc.

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]
  invoices      Invoice[]
  notes         ClientNote[]
}

model Opportunity {
  id                String    @id @default(cuid())
  workspaceId       String
  clientId          String
  title             String
  value             Float     @default(0)
  description       String?
  stage             String    @default("NEW") // NEW, NEGOTIATION, WON, LOST
  expectedCloseDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  stageId   String?
  stageRef  PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  
  userId    String?
  creator   User?    @relation("Creator", fields: [userId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   User?    @relation("OppAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model PipelineStage {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#579bfc")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunities Opportunity[]
}

model Activity {
  id          String   @id @default(cuid())
  clientId    String
  userId      String
  type        String   @default("NOTE") // CALL, MEETING, EMAIL, NOTE
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  type      String   @default("NOTE") // NOTE, CALL, MEETING
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, DONE, DONE, WORKING, STUCK, WAITING, NOT_STARTED
  assigneeId  String?
  dueDate     DateTime?

  // CRM specific field
  clientId    String?
  priority    String    @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  group       String    @default("هذا الأسبوع")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee  User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String   // CREATE, UPDATE, DELETE
  entityType  String   // TASK, CLIENT, OPPORTUNITY
  entityId    String
  entityName  String?  // Name/Title of the entity for quick display
  description String?  // Human readable description
  oldData     String?  // JSON string of data before change
  newData     String?  // JSON string of data after change
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  date        DateTime  @default(now())
  checkIn     DateTime  @default(now())
  checkOut    DateTime?
  status      String    @default("PRESENT") // PRESENT, ABSENT, LEAVE
  notes       String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Invoice & Billing Models
// ============================================

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  
  number      String    // e.g., INV-0001
  status      String    @default("DRAFT") // DRAFT, SENT, PAID, CANCELLED
  issueDate   DateTime  @default(now())
  dueDate     DateTime?
  
  subTotal    Float     @default(0)
  taxRate     Float     @default(15) // Standard KSA VAT
  taxAmount   Float     @default(0)
  totalAmount Float     @default(0)
  
  items       InvoiceItem[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  total       Float    @default(0)
}
